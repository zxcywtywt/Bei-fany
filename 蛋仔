-- 敌人碰撞箱调节相关
local currentEnemyCollisionMultiplier = 0 -- 0为关闭状态
local enemyCollisionData = {} -- 存储每个敌人角色的原始数据与显示框

local function applyEnemyCollision(character, multiplier)
    if not character then return end
    local Humanoid = character:FindFirstChildOfClass("Humanoid")
    local HumanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not Humanoid or not HumanoidRootPart then return end

    if not enemyCollisionData[character] then
        local originalCanCollide = {}
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                originalCanCollide[part] = part.CanCollide
            end
        end

        -- 创建半青色碰撞范围线框
        local displayBox = Instance.new("SelectionBox")
        displayBox.Name = "EnemyCollisionBox"
        displayBox.Adornee = HumanoidRootPart
        displayBox.Color3 = Color3.fromRGB(0, 255, 255) -- 青色
        displayBox.Transparency = 0.5 -- 半透明
        displayBox.LineThickness = 0.05
        displayBox.SurfaceTransparency = 1 -- 仅线框，表面透明
        displayBox.Visible = multiplier > 0
        displayBox.Parent = HumanoidRootPart

        enemyCollisionData[character] = {
            originalSize = HumanoidRootPart.Size,
            originalHipHeight = Humanoid.HipHeight,
            originalCanCollide = originalCanCollide,
            displayBox = displayBox
        }

        character.Destroying:Connect(function()
            enemyCollisionData[character] = nil
        end)
    end

    local data = enemyCollisionData[character]
    if multiplier <= 0 then
        for part, originalState in pairs(data.originalCanCollide) do
            if part:IsDescendantOf(character) then
                part.CanCollide = originalState
            end
        end
        HumanoidRootPart.Size = data.originalSize
        Humanoid.HipHeight = data.originalHipHeight
        data.displayBox.Visible = false
    else
        for part, _ in pairs(data.originalCanCollide) do
            if part:IsDescendantOf(character) then
                part.CanCollide = (part == HumanoidRootPart)
            end
        end
        HumanoidRootPart.Size = data.originalSize * multiplier
        Humanoid.HipHeight = data.originalHipHeight * multiplier
        data.displayBox.Visible = true
    end
end

local function onPlayerAdded(player)
    if player == LocalPlayer then return end

    player.CharacterAdded:Connect(function(character)
        applyEnemyCollision(character, currentEnemyCollisionMultiplier)
    end)

    if player.Character then
        applyEnemyCollision(player.Character, currentEnemyCollisionMultiplier)
    end
end

Players.PlayerRemoving:Connect(function(player)
    if player.Character and enemyCollisionData[player.Character] then
        enemyCollisionData[player.Character] = nil
    end
end)

for _, player in ipairs(Players:GetPlayers()) do
    if player ~= LocalPlayer then
        onPlayerAdded(player)
    end
end

local function onCharacterSpawn(character)
    local Humanoid = character:WaitForChild("Humanoid", 3)
    if not Humanoid then return end
    
    defaultWalkSpeed = Humanoid.WalkSpeed
    defaultJumpPower = Humanoid.JumpPower
    
    Humanoid.WalkSpeed = defaultWalkSpeed * currentWalkMultiplier
    Humanoid.JumpPower = defaultJumpPower * currentJumpMultiplier
end

if LocalPlayer.Character then
    onCharacterSpawn(LocalPlayer.Character)
end
LocalPlayer.CharacterAdded:Connect(onCharacterSpawn)

